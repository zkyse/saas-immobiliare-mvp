datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Tenants
model Tenant {
  id                String     @id @default(cuid())
  name              String
  slug              String     @unique
  logo              String?
  website           String?
  email             String
  phone             String?
  address           String?
  city              String?
  province          String?
  zipCode           String?
  
  plan              Plan       @default(FREE)
  status            TenantStatus @default(ACTIVE)
  
  users             User[]
  properties        Property[]
  contacts          Contact[]
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  @@index([slug])
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

// Users
model User {
  id                String     @id @default(cuid())
  tenantId          String
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  email             String     @unique
  password          String
  firstName         String
  lastName          String
  avatar            String?
  
  role              UserRole   @default(AGENT)
  status            UserStatus @default(ACTIVE)
  
  phone             String?
  department        String?
  
  lastLogin         DateTime?
  emailVerified     DateTime?
  
  properties        Property[]
  contacts          Contact[]
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

enum UserRole {
  ADMIN
  AGENT
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  DELETED
}

// Properties
model Property {
  id                String     @id @default(cuid())
  tenantId          String
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  agentId           String
  agent             User       @relation(fields: [agentId], references: [id])
  
  title             String
  description       String?
  type              PropertyType
  status            PropertyStatus
  
  address           String
  city              String
  province          String
  zipCode           String
  country           String
  latitude          Float?
  longitude         Float?
  
  rooms             Int
  bedrooms          Int
  bathrooms         Int
  squareMeters      Float
  floor             Int?
  yearBuilt         Int?
  
  price             Decimal    @db.Decimal(12, 2)
  pricePerSqm       Decimal    @db.Decimal(10, 2)
  currency          String     @default("EUR")
  
  features          String[]
  condition         String?
  
  images            PropertyImage[]
  
  visitCount        Int        @default(0)
  featured          Boolean    @default(false)
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  @@index([tenantId])
  @@index([agentId])
  @@index([type])
  @@index([status])
  @@index([city])
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  COMMERCIAL
  LAND
  OTHER
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
  SUSPENDED
}

// Property Images
model PropertyImage {
  id                String     @id @default(cuid())
  propertyId        String
  property          Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  url               String
  thumbnail         String?
  alt               String?
  caption           String?
  
  order             Int        @default(0)
  isFeatured        Boolean    @default(false)
  
  createdAt         DateTime   @default(now())
  
  @@index([propertyId])
}

// Contacts
model Contact {
  id                String     @id @default(cuid())
  tenantId          String
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdById       String
  createdBy         User       @relation(fields: [createdById], references: [id])
  
  firstName         String
  lastName          String
  email             String?
  phone             String?
  mobile            String?
  
  company           String?
  position          String?
  
  source            ContactSource
  status            ContactStatus
  
  notes             String?
  
  address           String?
  city              String?
  province          String?
  zipCode           String?
  
  interestedIn      String?
  budget            String?
  
  lastContact       DateTime?
  followUpDate      DateTime?
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  @@index([tenantId])
  @@index([email])
  @@index([phone])
  @@index([status])
}

enum ContactSource {
  WEBSITE
  PHONE
  EMAIL
  REFERRAL
  WALK_IN
  SOCIAL_MEDIA
  OTHER
}

enum ContactStatus {
  NEW
  PROSPECT
  QUALIFIED
  CONTACT
  CLIENT
  LOST
}
